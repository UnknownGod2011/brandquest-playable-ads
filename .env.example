# BrandQuest environment example
#
# Copy to .env.local for local development and replace placeholders with real
# server-side values. Never commit .env.local or any real secret values.

USE_DYNAMODB=false
AWS_REGION=us-east-1
BRANDQUEST_DYNAMODB_TABLE=BrandQuest
AWS_ACCESS_KEY_ID=replace-with-server-side-access-key
AWS_SECRET_ACCESS_KEY=replace-with-server-side-secret-key

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
AUTH_SECRET=replace-with-generated-secret
NEXTAUTH_SECRET=replace-with-same-generated-secret
NEXTAUTH_URL=http://localhost:3000

# Optional protected admin credentials provider.
# Store only a scrypt hash and salt here. Do not store plaintext passwords.
ADMIN_EMAIL=admin@brandquest.local
ADMIN_PASSWORD_HASH=replace-with-scrypt-hash
ADMIN_PASSWORD_SALT=replace-with-scrypt-salt

# Do not put secrets in NEXT_PUBLIC_* variables.
