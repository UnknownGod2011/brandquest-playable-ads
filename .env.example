# ----------------------------------------------------------------------------
# BrandQuest — Environment variables
#
# The app runs SAFELY with NONE of these set: it uses a no-op database adapter
# (empty data + real empty states) and a credential-free role "session". Add
# these only when you are ready to enable real persistence / auth.
# ----------------------------------------------------------------------------

# --- Database: Amazon DynamoDB (optional) -----------------------------------
# Set USE_DYNAMODB=true AND the values below to switch from the no-op adapter to
# the real DynamoDB adapter (lib/db/dynamodb.ts). Uses a single-table design.
USE_DYNAMODB=false
AWS_REGION=us-east-1
BRANDQUEST_DYNAMODB_TABLE=brandquest
# Credentials: prefer an instance/role in production. For local dev you may use:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Authentication (optional, prepared but not active) ---------------------
# When you wire in a real auth provider (see lib/auth/auth.config.ts), add:
# AUTH_SECRET=            # server-only. Generate: openssl rand -base64 32
# GOOGLE_CLIENT_ID=       # server-only
# GOOGLE_CLIENT_SECRET=   # server-only
#
# IMPORTANT: never prefix secrets with NEXT_PUBLIC_. They must stay server-only.
